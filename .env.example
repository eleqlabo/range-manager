# ── Gemini API ────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Supabase PostgreSQL ───────────────────────────────────────
DATABASE_URL=postgresql://postgres.toordleogaxlcnytatvz:[DB_PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://toordleogaxlcnytatvz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── JWT ───────────────────────────────────────────────────────
