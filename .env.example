# ── Gemini API ────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Supabase PostgreSQL ───────────────────────────────────────
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# ── JWT ───────────────────────────────────────────────────────
SECRET_KEY=change_this_to_random_32char_string_minimum

# ── CORS ──────────────────────────────────────────────────────
FRONTEND_URL=https://range-manager-demo.vercel.app
# CORS_ORIGIN=https://your-custom-domain.com  # 追加ドメインが必要な場合

# ── LINE Messaging API ────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# ── Node ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
